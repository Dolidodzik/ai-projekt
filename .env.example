APP_PORT=8080
VITE_PORT=5173
DB_PORT=5432

# PostgreSQL (docker-compose + Laravel)
POSTGRES_DB=ai2_projekt
POSTGRES_USER=ai2_user
POSTGRES_PASSWORD=ai2_secret

APP_NAME=AI2
APP_ENV=local
APP_DEBUG=true
# Produkcja: APP_ENV=production, APP_DEBUG=false
APP_URL=http://localhost:8080
APP_KEY=

DB_CONNECTION=pgsql
DB_HOST=db
DB_DATABASE=ai2_projekt
DB_USERNAME=ai2_user
DB_PASSWORD=ai2_secret

# Przy polaczeniu z hosta (DBeaver, pgAdmin, artisan poza Dockerem):
# DB_HOST=127.0.0.1

ADMIN_SEED_NAME=Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=password123
